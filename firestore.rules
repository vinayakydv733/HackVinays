rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().role == 'admin';
    }

    function isVolunteer() {
      return isAuthenticated() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (getUserData().role == 'volunteer' || getUserData().role == 'volunteers');
    }

    function isParticipant() {
      return isAuthenticated() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (getUserData().role == 'participant' || getUserData().role == 'participants');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function belongsToTeam(teamId) {
      return isAuthenticated() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().teamId == teamId;
    }

    // ── Admins: Full Access ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      // ✅ KEY FIX: Allow create if auth UID matches OR if user is admin
      // This is called during registration or when admin adds a volunteer
      allow create: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();

      // Read own profile
      // Read profile if owner, volunteer, or same team member
      allow read: if isOwner(userId) || isVolunteer() || (isAuthenticated() && getUserData().teamId == resource.data.teamId);

      // Update own profile but cannot change role or uid
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid;
    }

    // ── Teams Collection ──────────────────────────────────────────
    match /teams/{teamId} {
      // Anyone can read teams (needed for registration dropdown)
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || isVolunteer();
      allow delete: if isAdmin();
    }

    // ── Announcements ─────────────────────────────────────────────
    match /announcements/{annId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isVolunteer();
      allow delete: if isAdmin();
    }

    // ── Events / Schedule ─────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Projects ──────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isParticipant();
      allow update: if isParticipant() && belongsToTeam(resource.data.teamId);
      allow delete: if isAdmin();
    }

    // ── Scores ────────────────────────────────────────────────────
    match /scores/{scoreId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isVolunteer();
      allow delete: if isAdmin();
    }

    // ── Help Requests (Passes, SOS, Tech) ─────────────────────────
    match /help_requests/{requestId} {
      // Participant reads their own team's requests
      allow read: if isAuthenticated();
      // Anyone authenticated can create (SOS, tech, passes)
      allow create: if isAuthenticated();
      // Volunteers can update (approve/reject passes)
      allow update: if isVolunteer() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Meals ─────────────────────────────────────────────────────
    match /meals/{mealId} {
      allow read: if isAuthenticated();
      allow create: if isVolunteer() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Volunteer Tasks ───────────────────────────────────────────
    match /volunteer_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      // Volunteers can update status (mark complete)
      allow update: if isVolunteer() || isAdmin();
    }

    // ── Advice (Mentor Feedback) ──────────────────────────────────
    match /advice/{adviceId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      // Participants can only toggle 'implemented' field
      allow update: if isParticipant() 
        && request.resource.data.diff(resource.data)
           .affectedKeys().hasOnly(['implemented']);
    }

    // ── Volunteers Collection ─────────────────────────────────────
    match /volunteers/{volId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Settings (Hackathon Timer etc.) ───────────────────────────
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Mentors ───────────────────────────────────────────────────
    match /mentors/{mentorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
