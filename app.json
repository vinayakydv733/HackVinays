{
  "expo": {
    "name": "HV",
    "slug": "my_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/new_app_icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/new_app_icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a1a",
        "foregroundImage": "./assets/images/new_app_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.codenexusjitb.my_app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/new_app_icon.png",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a1a",
          "image": "./assets/images/new_app_icon.png",
          "imageWidth": 150
        }
      ],
      "expo-image",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-sharing",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f68fe6ee-71f2-444e-b98b-f53ea1726d9c"
      }
    },
    "owner": "codenexus.jitb"
  }
}
